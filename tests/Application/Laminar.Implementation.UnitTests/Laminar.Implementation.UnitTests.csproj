    <ItemGroup>
      <Folder Include="Base.UnitTests\UserInterface.UnitTests\" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\..\src\Application\Laminar.Implementation\Laminar.Implementation.csproj" />
