<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uid="using:Laminar.PluginFramework.UserInterface.UserInterfaceDefinitions"
             xmlns:local="using:BasicFunctionality.Avalonia"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="40" d:DataContext="{x:Static uid:DefaultViewer.DesignInstance}"
             x:DataType="uid:DefaultViewer+IXamlTarget"
             x:Class="BasicFunctionality.Avalonia.UserControls.DefaultDisplay">
	<local:ValueEditorPanel>
		<TextBlock local:ValueEditorPanel.Position="Nameplate" 
		           Text="{Binding Name}" 
		           VerticalAlignment="Center"/>
	</local:ValueEditorPanel>
</UserControl>
