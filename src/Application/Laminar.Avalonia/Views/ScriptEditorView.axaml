<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Laminar.Avalonia.ViewModels"
             xmlns:sam="using:Laminar.Avalonia.SelectAndMove"
             xmlns:scr="using:Laminar.Contracts.Scripting.NodeWrapping"
             xmlns:s="using:Laminar.Avalonia.Settings"
             xmlns:init="using:Laminar.Avalonia.InitializationTargets"
             xmlns:m="using:Laminar.Avalonia.Markup"
             xmlns:anim="using:Laminar.Avalonia.Animations"
             xmlns:dd="using:Laminar.Avalonia.DragDrop"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Laminar.Avalonia.Views.ScriptEditorView"
             x:DataType="vm:ScriptEditorViewModel"
             Background="Transparent"
             IsHitTestVisible="True">
    <UserControl.Resources>
        <m:ConnectorRegistry x:Key="{x:Static m:ConnectorRegistry.Key}"/>
    </UserControl.Resources>
    
    <sam:SelectAndMove ItemsSource="{Binding VisualElements}" 
                       ClipToBounds="True"
                       dd:DropTargetHandler.DropCommand="{Binding DropCommand}">
        <sam:SelectAndMove.Styles>
            <Style Selector="sam|SelectAndMove > ContentPresenter" x:DataType="scr:IWrappedNode">
                <Setter Property="Canvas.Left" Value="{Binding Location.Value.X}"/>
                <Setter Property="Canvas.Top" Value="{Binding Location.Value.Y}"/>
                <Setter Property="anim:ScaleAnimation.Duration" Value="{s:Setting InterfaceSettings.AnimationDuration}"/>
            </Style>
        </sam:SelectAndMove.Styles>
    </sam:SelectAndMove>
</UserControl>
