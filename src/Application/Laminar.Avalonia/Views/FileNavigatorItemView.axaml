<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Laminar.Avalonia.ViewModels"
             xmlns:c="using:Laminar.Avalonia.Controls"
             xmlns:shapes="using:Laminar.Avalonia.Shapes"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Laminar.Avalonia.Views.FileNavigatorItemView"
             x:DataType="vm:FileNavigatorItemViewModel">
    <DockPanel Tag="{Binding ItemTypeName}"
               HorizontalAlignment="Stretch"
               Background="Transparent"
               IsHitTestVisible="True"
               Height="37">
        <ItemsControl DockPanel.Dock="Right"
                      Name="PART_QuickAccess"
                      ItemsSource="{Binding 
                                            Converter={StaticResource ToolInstancer}, 
                                            ConverterParameter={StaticResource Tools.FileNavigator.StorageItem}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="3" Height="32"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
        <PathIcon Height="16" Width="16" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="3,0,0,0">
            <PathIcon.Data>
                <MultiBinding Converter="{StaticResource SwitchConverter}">
                    <Binding Path="ItemTypeName"/>
                    <Binding Source="{x:Static shapes:PathData.FolderIcon}" Converter="{StaticResource SwitchItemConverter}" ConverterParameter="folder"/>
                    <Binding Source="{x:Static shapes:PathData.ScriptIcon}" Converter="{StaticResource SwitchItemConverter}" ConverterParameter="script"/>
                </MultiBinding>
            </PathIcon.Data>
        </PathIcon>
        <c:EditableLabel VerticalAlignment="Center" 
                         Text="{Binding Name, Mode=TwoWay}" 
                         IsBeingEdited="{Binding CoreItem.NeedsName, Mode=TwoWay}"
                         Margin="4,0,0,0"/>
        
        <DockPanel.Styles>
            <Style Selector="DockPanel > ItemsControl#PART_QuickAccess">
                <Setter Property="IsVisible" Value="False"/>
            </Style>
            
            <Style Selector="DockPanel:pointerover > ItemsControl#PART_QuickAccess">
                <Setter Property="IsVisible" Value="True"/>
            </Style>
        </DockPanel.Styles>
    </DockPanel>
</UserControl>
