<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Laminar.Avalonia.ViewModels"
             xmlns:dvm="using:Laminar.Avalonia.ViewModels.Design"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" d:DataContext="{x:Static dvm:DesignViewModel.Settings}"
             x:Class="Laminar.Avalonia.Views.SettingsView"	
             x:DataType="vm:SettingsViewModel"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
	<ItemsControl ItemsSource="{StaticResource SettingsRoot}" MaxWidth="1500" Margin="100, 30" HorizontalAlignment="Stretch">
		<ItemsControl.ItemsPanel>
			<ItemsPanelTemplate>
				<StackPanel Spacing="4"/>			
			</ItemsPanelTemplate>
		</ItemsControl.ItemsPanel>
		
		<ItemsControl.ItemTemplate>
			<DataTemplate>
				<Border
					CornerRadius="10"
					Background="#2555">
					<ContentControl
						Content="{Binding}" Margin="20"/>
				</Border>
			</DataTemplate>
		</ItemsControl.ItemTemplate>
	</ItemsControl>
</UserControl>
