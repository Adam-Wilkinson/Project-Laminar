<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Laminar.Avalonia.ViewModels"
             xmlns:dvm="using:Laminar.Avalonia.ViewModels.Design"
             xmlns:toolSystem="clr-namespace:Laminar.Avalonia.ToolSystem"
             xmlns:c="using:Laminar.Avalonia.Controls"
             xmlns:shapes="using:Laminar.Avalonia.Shapes"
             xmlns:s="using:Laminar.Avalonia.Settings"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="450" d:DataContext="{x:Static dvm:DesignViewModel.Settings}"
             x:Class="Laminar.Avalonia.Views.SettingsView"	
             x:DataType="vm:SettingsViewModel"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
	<TabControl MaxWidth="1500" Margin="100, 30" TabStripPlacement="Top">
		<TabItem Header="Settings">
			<ItemsControl HorizontalAlignment="Stretch" 
			              Grid.IsSharedSizeScope="True"
			              ItemsSource="{StaticResource SettingsRoot}" 
			              ItemTemplate="{StaticResource SettingDataTemplate}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="1" VerticalAlignment="Top" RowSpacing="5"/>			
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
			</ItemsControl>
		</TabItem>
		
		<TabItem Header="Keybindings">
			<ScrollViewer>
				<ItemsControl ItemsSource="{StaticResource {x:Static toolSystem:Tool.ToolRootKey}}"
				              Margin="20,10"
				              Grid.IsSharedSizeScope="True"/>
			</ScrollViewer>
			<TabItem.DataTemplates>
				<DataTemplate x:DataType="toolSystem:Toolbox">
					<StackPanel>
						<TextBlock Text="{Binding NameKey}" Margin="0,15,0,0"/>
						<ItemsControl Margin="15,0,0,0" ItemsSource="{Binding}"/>
					</StackPanel>
				</DataTemplate>
				
				<DataTemplate x:DataType="toolSystem:Tool">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto" SharedSizeGroup="Keybindings"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Margin="0,15,0,0"
						           Text="{Binding NameKey}"/>
						<Separator Grid.Column="1" VerticalAlignment="Bottom"/>
						<c:KeyGestureInterface Grid.Column="2" Name="MainKeyGestureInterface"
						                       CornerRadius="{s:UiScaled 10}"
						                       Width="300"
						                       Gesture="{Binding Gesture, Mode=TwoWay}" 
						                       DockPanel.Dock="Right"/>
						<Button Grid.Column="3" ToolTip.Tip="Remove" Classes="KeyBindingAction" 
						        Command="{Binding SetGestureToNone}">
							<PathIcon Margin="{s:UiScaled 12}" Width="{s:UiScaled 20}" Height="{s:UiScaled 20}"
							          Data="{x:Static shapes:PathData.CrossWithCircle}"/>
						</Button>
						<Button Grid.Column="4" ToolTip.Tip="Reset" Classes="KeyBindingAction"
						        Command="{Binding ResetGesture}">
							<PathIcon Margin="{s:UiScaled 12}" Width="{s:UiScaled 20}" Height="{s:UiScaled 20}"
							          Data="{x:Static shapes:PathData.ResetIcon}"/>
						</Button>
						
						<Grid.Styles>
							<Style Selector="Button.KeyBindingAction">
								<Setter Property="VerticalAlignment" Value="Stretch"/>
								<Setter Property="Margin" Value="2"/>
								<Setter Property="CornerRadius" Value="{s:UiScaled 10}"/>
								<Setter Property="Background" Value="{DynamicResource UiLayer}"/>
								<Setter Property="Width" Value="{Binding $self.Bounds.Height}"/>
								<Setter Property="ToolTip.ShowDelay" Value="300"/>
							</Style>
						</Grid.Styles>
					</Grid>
				</DataTemplate>
			</TabItem.DataTemplates>
		</TabItem>
	</TabControl>
</UserControl>
