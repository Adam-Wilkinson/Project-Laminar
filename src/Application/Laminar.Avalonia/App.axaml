<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Laminar.Avalonia.App"
             xmlns:vms="using:Laminar.Avalonia.ViewModels.Services"
             xmlns:t="using:Laminar.Avalonia.ToolSystem"
             xmlns:s="using:Laminar.Avalonia.Settings"
             xmlns:conv="using:Laminar.Avalonia.Converters">

    <Application.DataTemplates>
        <vms:ViewLocator/>
        <DataTemplate DataType="t:ToolInstance">
	        <Button Theme="{StaticResource ToolButton}"/>
        </DataTemplate>
    </Application.DataTemplates>

	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="XamlAssets/Resources/LaminarColorResources.axaml"/>
				<ResourceInclude Source="XamlAssets/Resources/ToolResources.axaml"/>
				<ResourceInclude Source="XamlAssets/Resources/SettingsResources.axaml"/>
				<ResourceInclude Source="XamlAssets/Themes/ToolButtonTheme.axaml"/>
				<ResourceInclude Source="XamlAssets/Themes/ToolMenuItemTheme.axaml"/>
				<ResourceInclude Source="XamlAssets/Themes/GeometryIconTheme.axaml"/>
				<ResourceInclude Source="XamlAssets/Themes/SwitchIconTheme.axaml"/>
				<ResourceInclude Source="XamlAssets/Themes/LineIconTheme.axaml"/>
			</ResourceDictionary.MergedDictionaries>
			
			<conv:FirstNotNullValueConverter x:Key="FirstNotNullValueConverter"/>
			<conv:NullOrEmptyConverter x:Key="NullOrEmptyConverter"/>
			<conv:ToolInstancingConverter x:Key="ToolInstancer"/>
			<conv:ToStringConverter x:Key="ToStringConverter"/>
			<conv:MillisecondsFromTimespanConverter x:Key="MillisecondsFromTimespanConverter"/>
			<conv:MultiplyConverter x:Key="MultiplyConverter"/>
			<conv:NullifyIfNoneConverter x:Key="NullifyIfNoneConverter"/>
			<conv:HasValueConverter x:Key="HasValueConverter"/>
			<conv:SwitchConverter x:Key="SwitchConverter"/>
			<conv:SwitchItemConverter x:Key="SwitchItemConverter"/>
			<conv:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
		</ResourceDictionary>
	</Application.Resources>
	
	<Application.Styles>
		<StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
		<FluentTheme DensityStyle="{s:Setting InterfaceSettings.Density}">
			<FluentTheme.Palettes>
				
			</FluentTheme.Palettes>
		</FluentTheme>
		<StyleInclude Source="XamlAssets/Styles/FontStyles.axaml"/>
	</Application.Styles>
</Application>