<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:scr="using:Laminar.Contracts.Scripting.NodeWrapping"
                    xmlns:c="using:Laminar.Avalonia.Controls"
                    xmlns:t="using:Laminar.Avalonia.ToolSystem"
                    xmlns:comp="using:Laminar.PluginFramework.NodeSystem.Components"
                    xmlns:conn="using:Laminar.PluginFramework.NodeSystem.Connectors"
                    xmlns:sam="using:Laminar.Avalonia.SelectAndMove"
                    xmlns:s="using:Laminar.Avalonia.Settings"
                    xmlns:m="using:Laminar.Avalonia.Markup"
                    xmlns:init="using:Laminar.Avalonia.InitializationTargets">
    <ControlTheme TargetType="c:Connector" x:Key="IoConnectorPath" x:DataType="conn:IConnector">
        <Setter Property="IsVisible" Value="{Binding Converter={x:Static ObjectConverters.IsNotNull}}"/>
        <Setter Property="Fill" Value="{Binding ColorHex, TargetNullValue={x:Static Brushes.White}, Converter={StaticResource ParseBrushConverter}}"/>
        <Setter Property="Stroke" Value="Gray"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="ConnectionWidth" Value="13"/>
        <Setter Property="TipLength" Value="10"/>
        <Setter Property="m:ConnectorRegistry.RegisteredConnector" Value="{Binding}"/>
        <Setter Property="Classes.HasConnections" Value="{Binding Flags, Converter={StaticResource HasFlagConverter}, ConverterParameter={x:Static conn:ConnectorFlags.HasConnections}}"/>
        <Setter Property="Classes.HasNoConnections" Value="{Binding Flags, Converter={StaticResource MissingFlagConverter}, ConverterParameter={x:Static conn:ConnectorFlags.HasConnections}}"/>
        <Setter Property="Width" Value="0"/>
        <Setter Property="Height" Value="0"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="ConnectionWidth" Duration="{s:Setting InterfaceSettings.AnimationDuration}"/>
                <DoubleTransition Property="Opacity" Duration="{s:Setting InterfaceSettings.AnimationDuration}"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="{s:Setting InterfaceSettings.AnimationDuration}"/>
            </Transitions>
        </Setter>
        
        <Style Selector="^:pointerover">
            <Setter Property="ConnectionWidth" Value="15"/>
        </Style>
        
        <Style Selector="^:drag-active">
            <Setter Property="ConnectionWidth" Value="10"/>
        </Style>
    </ControlTheme>
    
    <DataTemplate DataType="comp:INodeRow" x:Key="NodeRowDataTemplate">
        <Panel Name="NodeRowRoot"
               Opacity="{Binding Opacity.Value}"
               ClipToBounds="False">
            <ContentControl Name="CentralDisplay" 
                            Content="{Binding CentralDisplay}"
                            ClipToBounds="False"/>
            
            <c:Connector Theme="{StaticResource IoConnectorPath}" 
                         HorizontalAlignment="Left"
                         RenderTransform="{m:ConnectorRenderTransformCalculator CollapsedNodeHeight=40}"
                         DragMode="{Binding $self.(m:ConnectorRegistry.ConnectorGestureLive), 
                            Converter={StaticResource ParameterOrNullConverter}, 
                            ConverterParameter={x:Static c:ConnectorDragMode.MoveStart},
                            TargetNullValue={x:Static c:ConnectorDragMode.None}}"
                         DataContext="{Binding InputConnector}"/>
            
            <c:Connector Theme="{StaticResource IoConnectorPath}"
                         HorizontalAlignment="Right"
                         RenderTransform="{m:ConnectorRenderTransformCalculator CollapsedNodeHeight=40}"
                         DragMode="{Binding $self.(m:ConnectorRegistry.ConnectorGestureLive), 
                            Converter={StaticResource ParameterOrNullConverter}, 
                            ConverterParameter={x:Static c:ConnectorDragMode.MoveEnd},
                            TargetNullValue={x:Static c:ConnectorDragMode.None}}"
                         DataContext="{Binding OutputConnector}"/>
        </Panel>
    </DataTemplate>
    
    <DataTemplate DataType="scr:IWrappedNode" x:Key="WrappedNodeDataTemplate">
        <Panel Name="NodeRoot" ClipToBounds="False"
               Background="{DynamicResource {x:Static init:ColorInitialization.LaminarNonForegroundKey}}">
            <t:ToolMenu.ContextToolbox>
                <t:Toolbox NameKey="Node" x:DataType="scr:IWrappedNode">
                    <StaticResource ResourceKey="Tools.ScriptEditor.NodeTools.ToggleExpanded"/>
                </t:Toolbox>
            </t:ToolMenu.ContextToolbox>
            
            <Border Name="MainPanelBorder"
                    Background="{DynamicResource {x:Static init:ColorInitialization.LaminarNonForegroundKey}}"
                    VerticalAlignment="Top"
                    ClipToBounds="False"
                    BorderThickness="3">
                <DockPanel Width="250" ClipToBounds="False">
                    <Panel DockPanel.Dock="Top" HorizontalAlignment="Stretch">
                        <ContentControl Content="{Binding NameRow}" 
                                        ClipToBounds="False"
                                        Height="40"
                                        Background="{DynamicResource {x:Static init:ColorInitialization.LaminarAccentBackgroundKey}}"/>
                        <Button Margin="5,0,0,0"
                                Height="30"
                                Width="30"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                IsVisible="{Binding $parent.((scr:IWrappedNode)DataContext)?.Rows, Converter={StaticResource HasValueConverter}, TargetNullValue={x:False}}"
                                DataContext="{Binding 
                                    Converter={StaticResource ToolInstancer},
                                    ConverterParameter={StaticResource Tools.ScriptEditor.NodeTools.ToggleExpanded}}"
                                Theme="{StaticResource ToolButton}"/>
                    </Panel>
                    <ItemsControl ItemsSource="{Binding Rows}"
                                  Background="{DynamicResource {x:Static init:ColorInitialization.LaminarNonForegroundKey}}"
                                  Classes.IsCollapsed="{Binding IsCollapsed.Value}"
                                  ClipToBounds="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel ClipToBounds="False"
                                            Background="{DynamicResource {x:Static init:ColorInitialization.LaminarNonForegroundKey}}"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl > ContentPresenter > Panel#NodeRowRoot">
                                <Style Selector="^ > ContentControl#CentralDisplay">
                                    <Setter Property="Height" Value="{s:UiScaled 40}"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="Transitions">
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="{s:Setting InterfaceSettings.AnimationDuration}"/>
                                            <DoubleTransition Property="Height" Duration="{s:Setting InterfaceSettings.AnimationDuration}"/>
                                            <ThicknessTransition Property="Margin" Duration="{s:Setting InterfaceSettings.AnimationDuration}"/>
                                        </Transitions>
                                    </Setter>
                                </Style>
                            </Style>
                            
                            <Style Selector="ItemsControl.IsCollapsed > ContentPresenter > Panel#NodeRowRoot">
                                <Style Selector="^ > ContentControl#CentralDisplay">
                                    <Setter Property="Height" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Opacity" Value="0"/>
                                </Style>
                                
                                <Style Selector="^ > c|Connector.HasNoConnections">
                                    <Setter Property="Opacity" Value="0"/>
                                </Style>
                            </Style>
                        </ItemsControl.Styles>
                        
                    </ItemsControl>
                </DockPanel>
            </Border>
            
            <Rectangle Name="HoverHighlight" 
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       IsHitTestVisible="False"
                       Fill="Gray"/>
            
            <Panel.Styles>
                <Style Selector="Panel#NodeRoot Rectangle#HoverHighlight">
                    <Setter Property="Opacity" Value="0"/>
                </Style>
                
                <Style Selector="Panel#NodeRoot:pointerover Rectangle#HoverHighlight">
                    <Setter Property="Opacity" Value="0.1"/>
                </Style>
                
                <Style Selector="Panel#NodeRoot[(sam|Selection.IsSelected)=True] Border#MainPanelBorder">
                    <Setter Property="BorderBrush" Value="Gray"/>
                </Style>
                
                <Style Selector="Panel#NodeRoot[(sam|Selection.IsSelected)=False] Border#MainPanelBorder">
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static init:ColorInitialization.LaminarNonForegroundKey}}"/>
                </Style>
            </Panel.Styles>
        </Panel>
    </DataTemplate>
</ResourceDictionary>
