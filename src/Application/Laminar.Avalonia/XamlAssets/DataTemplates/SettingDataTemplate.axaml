<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="using:Laminar.Avalonia.Settings"
                    xmlns:t="using:Laminar.Avalonia.ToolSystem">
    <DataTemplate x:Key="SettingDataTemplate" x:DataType="s:Setting">
        <Grid HorizontalAlignment="Stretch" IsVisible="{Binding DisplayToUser}">
            
            <t:ToolMenu.ContextToolbox>
                <t:Toolbox NameKey="Setting" DataType="s:Setting">
                    <StaticResource ResourceKey="Tools.Settings.ResetSettingTool"/>
                </t:Toolbox>
            </t:ToolMenu.ContextToolbox>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="ResetSetting"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Name="SettingBorder"
                    CornerRadius="{s:UiScaled 10}">
                <ContentControl Name="SettingControl"
                                MinHeight="{s:UiScaled 40}"
                                Content="{Binding}" 
                                Margin="{s:UiScaled 10}"/>
            </Border>
            <Button Grid.Column="1"
                    Height="{Binding #SettingControl.Bounds.Height}"
                    CornerRadius="{s:UiScaled 10}"
                    Background="{DynamicResource UiLayer}"
                    DataContext="{Binding 
										Converter={StaticResource ToolInstancer}, 
										ConverterParameter={StaticResource Tools.Settings.ResetSettingTool}}"
                    Theme="{StaticResource ToolButton}"
                    VerticalAlignment="Stretch"
                    Width="{Binding $self.Bounds.Height}"
                    Margin="{s:UiScaled '5,0,0,0'}">
            </Button>
					
            <Grid.Styles>
                <Style Selector="Border#SettingBorder">
                    <Setter Property="Background" Value="{DynamicResource UiLayer}"/>
                    <Setter Property="Transitions">
                        <Transitions>
                            <BrushTransition Property="Background" Duration="{s:Setting InterfaceSettings.AnimationDuration}"/>
                        </Transitions>
                    </Setter>
                    <Style Selector="^:pointerover">
                        <Setter Property="Background" Value="{DynamicResource UiLayerHighlight}"/>
                    </Style>
                </Style>
            </Grid.Styles>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
