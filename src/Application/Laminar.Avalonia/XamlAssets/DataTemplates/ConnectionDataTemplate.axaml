<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conn="using:Laminar.Contracts.Scripting.Connection"
                    xmlns:m="using:Laminar.Avalonia.Markup"
                    x:CompileBindings="True">
    <DataTemplate DataType="conn:IConnection" x:Key="ConnectionDataTemplate">
        <Line StartPoint="{m:ConnectorLocation {CompiledBinding InputConnector}}"/>
    </DataTemplate>
</ResourceDictionary>
