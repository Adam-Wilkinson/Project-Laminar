<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTheme x:Key="DragDropTreeViewTheme" TargetType="TreeView"
                  BasedOn="{StaticResource {x:Type TreeView}}">
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="ItemContainerTheme" Value="{StaticResource DragDropTreeViewItemTheme}"></Setter>
        <Style Selector="^ /template/ ScrollViewer">
            <Setter Property="ClipToBounds" Value="False"/>
            <Style Selector="^ /template/ ScrollContentPresenter#PART_ContentPresenter">
                <Setter Property="ClipToBounds" Value="False"/>
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>
