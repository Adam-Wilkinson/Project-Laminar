<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="using:Laminar.Avalonia.Controls">
    <Design.PreviewWith>
        <Panel Margin="10">
            <c:KeyGestureEditor Gesture="Ctrl+a" Width="150"/>
        </Panel>
    </Design.PreviewWith>
    
    <StaticResource x:Key="KeyGestureEditorBackground" ResourceKey="UiLayer"/>
    <StaticResource x:Key="KeyGestureEditorBackgroundPointerOver" ResourceKey="SystemControlBackgroundAltMediumLowBrush"/>
    <StaticResource x:Key="KeyGestureEditorBackgroundDisabled" ResourceKey="SystemControlBackgroundAltMediumBrush"/>
    <StaticResource x:Key="KeyGestureEditorBorderBrush" ResourceKey="SystemControlTransientBorderBrush"/>
    <StaticResource x:Key="KeyGestureEditorBorderBrushFocused" ResourceKey="SystemControlHighlightAccentBrush"/>
    
    <ControlTheme TargetType="c:KeyGestureEditor" x:Key="{x:Type c:KeyGestureEditor}">
        <Setter Property="Background" Value="{DynamicResource KeyGestureEditorBackground}"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_BorderElement"
                        BorderThickness="3"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <TextBlock Text="{TemplateBinding Text}" 
                               Margin="5" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
        
        <Style Selector="^ /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource KeyGestureEditorBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource KeyGestureEditorBorderBrush}"/>
        </Style>
        
        <Style Selector="^:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource KeyGestureEditorBackgroundPointerOver}"/>
        </Style>
        
        <Style Selector="^:disabled /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource KeyGestureEditorBackgroundDisabled}"/>
        </Style>
        
        <Style Selector="^:isBeingEdited /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource KeyGestureEditorBorderBrushFocused}"/>
        </Style>
    </ControlTheme>
</ResourceDictionary>
