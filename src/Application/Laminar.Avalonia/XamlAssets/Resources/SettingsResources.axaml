<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

                    xmlns:d="using:Laminar.PluginFramework.UserInterface.UserInterfaceDefinitions"
                    xmlns:s="using:Laminar.Avalonia.Settings">
	
	<s:OptionsSetting x:Key="SettingsRoot.InterfaceSettings.ThemeVariant" Name="Theme" ValueIndex="0">
		<s:OptionsSettingValue Name="System Default" Value="{x:Static ThemeVariant.Default}"/>
		<s:OptionsSettingValue Name="Light" Value="{x:Static ThemeVariant.Light}"/>
		<s:OptionsSettingValue Name="Dark" Value="{x:Static ThemeVariant.Dark}"/>
	</s:OptionsSetting>
	
	<s:OptionsSetting x:Key="SettingsRoot.InterfaceSettings.Density" Name="UI Density" ValueIndex="0">
		<s:OptionsSettingValue Name="This should make new text" Value="{x:Static DensityStyle.Normal}"/>
		<s:OptionsSettingValue Name="Compact" Value="{x:Static DensityStyle.Compact}"/>
	</s:OptionsSetting>
	
	<s:TimeSpanSetting x:Key="SettingsRoot.InterfaceSettings.AnimationDuration" 
	                   Name="Animation Duration" 
	                   Value="0:0:0.2" 
	                   DisplayValueConverter="{StaticResource MillisecondsFromTimespanConverter}">
		<d:Slider Min="0" Max="300" FormatString="{}{0:0} ms"/>
	</s:TimeSpanSetting>

	<s:DoubleSetting x:Key="SettingsRoot.InterfaceSettings.UiScale" Name="User Interface Scale" Value="1">
		<d:Slider Min="0.4" Max="2.0" FormatString="{}{0:P0}"></d:Slider>
	</s:DoubleSetting>
	
	<s:BoolSetting x:Key="SettingsRoot.InterfaceSettings.ColorsFromTheme" Name="Determine Colors" Value="False">
		<d:BoolTwoButton TrueText="Manually" FalseText="Based on theme"/>
	</s:BoolSetting>
	<s:ColorSetting x:Key="SettingsRoot.InterfaceSettings.AccentColor" Name="Accent Colour" Value="#242ee0" DisplayToUser="{s:Setting InterfaceSettings.ColorsFromTheme}"/>
	<s:ColorSetting x:Key="SettingsRoot.InterfaceSettings.ForegroundColor" Name="Foreground Colour" Value="#dbe5ff" DisplayToUser="{s:Setting InterfaceSettings.ColorsFromTheme}"/>
	<s:ColorSetting x:Key="SettingsRoot.InterfaceSettings.BackgroundColor" Name="Background Colour" Value="#000002" DisplayToUser="{s:Setting InterfaceSettings.ColorsFromTheme}"/>
	
	<s:SettingsCategory x:Key="SettingsRoot" Name="Settings Root">
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.AnimationDuration"/>
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.ThemeVariant"/>
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.UiScale"/>
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.Density"/>
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.ColorsFromTheme"/>
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.AccentColor"/>
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.ForegroundColor"/>
		<StaticResource ResourceKey="SettingsRoot.InterfaceSettings.BackgroundColor"/>
	</s:SettingsCategory>
	
    <Easing x:Key="AnimationEasing">QuadraticEaseInOut</Easing>
	
</ResourceDictionary>
