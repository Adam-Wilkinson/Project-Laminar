<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key='LaminarForeground'>#dbe5ff</Color>
            <Color x:Key="LaminarForegroundEmphasis">#9eaedf</Color>
            <Color x:Key='LaminarBackground'>#010103</Color>
            <Color x:Key='LaminarPrimary'>#242ee0</Color>
            <Color x:Key='LaminarSecondary'>#000c2e</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <Color x:Key='LaminarForeground'>#000a24</Color>
            <Color x:Key="LaminarForegroundEmphasis">#505de8</Color>
            <Color x:Key='LaminarBackground'>#fafaff</Color>
            <Color x:Key='LaminarPrimary'>#1f29db</Color>
            <Color x:Key='LaminarSecondary'>#d1ddff</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
