<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:init="using:Laminar.Avalonia.InitializationTargets">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key='{x:Static init:ColorInitialization.LaminarForegroundKey}'>#dbe5ff</Color>
            <Color x:Key='{x:Static init:ColorInitialization.LaminarAccentKey}'>#242ee0</Color>
            <Color x:Key="LaminarBackground">#000002</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <Color x:Key='{x:Static init:ColorInitialization.LaminarForegroundKey}'>#000a24</Color>
            <Color x:Key='{x:Static init:ColorInitialization.LaminarAccentKey}'>#1f29db</Color>
            <Color x:Key="LaminarBackground">#eee</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
